# Blotato MCP handles media creation + scheduling
# API key is also set in .claude/settings.json for MCP auth
BLOTATO_API_KEY=

# Blotato connected account UUIDs (from app.blotato.com → Connected Accounts)
LINKEDIN_ACCOUNT_ID=
TWITTER_ACCOUNT_ID=
FACEBOOK_ACCOUNT_ID=
INSTAGRAM_ACCOUNT_ID=

# PostgreSQL connection (--from-db mode and GBP queue)
DATABASE_URL=
# Set to "false" to disable SSL (default: SSL enabled with rejectUnauthorized: false)
DATABASE_SSL=true

# Cloudflare R2 (GBP image uploads + Shorts video uploads)
R2_ACCOUNT_ID=
R2_API_TOKEN=
R2_BUCKET_NAME=gbp-images
R2_PUBLIC_URL=

# YouTube Shorts + Podcast — Fish Audio TTS voiceover
# Get your API key at https://fish.audio
# FISH_AUDIO_VOICE_ID is optional — omit to use the Fish Audio default voice
FISH_AUDIO_API_KEY=
FISH_AUDIO_VOICE_ID=

# Ghost CMS Admin API (podcast embed — prepends audio player to blog posts)
# Find in Ghost Admin → Settings → Integrations → Add Custom Integration
# Key format: {id}:{hex_secret}
GHOST_ADMIN_API_URL=
GHOST_ADMIN_API_KEY=

# RSS.com Podcast Hosting (Network plan required)
# Get API key from: RSS.com dashboard → profile photo → API Access
# Podcast ID: found in your RSS.com dashboard URL or API response
RSS_COM_API_KEY=
RSS_COM_PODCAST_ID=
